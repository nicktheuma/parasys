# --- Admin (single operator) ---
ADMIN_PASSWORD=change-me-in-production
SESSION_SECRET=use-a-long-random-string-at-least-32-chars

# --- Postgres (Neon recommended) ---
# Replace the whole line with the URI from Neon (Dashboard → Connect). Do not leave "host" as the hostname.
# Example shape: postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.neon.tech/neondb?sslmode=require

# --- Stripe (design package) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Public URL of this app (no trailing slash) — used for Checkout redirects and download links in emails
PUBLIC_APP_URL=http://localhost:5173

# Transactional email (Resend — https://resend.com). Omit to skip receipt emails (order + token still saved).
# RESEND_API_KEY=re_...
# EMAIL_FROM=Parasys <onboarding@resend.dev>

# Dev only: ZIP download (placeholder PDF + STL) without Stripe. Omit or false in production.
ALLOW_FREE_DESIGN_PACKAGE=true

# Optional: if the browser calls a different API origin (leave empty when using Vite proxy)
# VITE_API_BASE=

# Optional: asset base path for static hosting under a subpath (GitHub Pages project site).
# Example: VITE_BASE_PATH=/parasys  (omit or "/" for Vercel root deploys)
# VITE_BASE_PATH=

# --- Vercel CLI (optional; see README “Vercel CLI credentials”) ---
# Copy .env.vercel.local.example → .env.vercel.local and set VERCEL_TOKEN, or use `vercel login`.
